/dts-v1/;

#include <nxp/lpc/nxp_lpc845.dtsi>
#include <zephyr/dt-bindings/pinctrl/lpc84x-pinctrl.h>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "NXP LPC845-BRK Board";
	compatible = "nxp,lpc845-brk";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
	};

	aliases {
		led0 = &led0;
		led1 = &led1;
		led2 = &led2;
		sw0 = &user_btn;
	};

	leds {
		compatible = "gpio-leds";

		led0: led_0 {
			gpios = <&gpio1 0 GPIO_ACTIVE_LOW>;
			label = "RGB Green Led";
		};

		led1: led_1 {
			gpios = <&gpio1 1 GPIO_ACTIVE_LOW>;
			label = "RGB Blue Led";
		};

		led2: led_2 {
			gpios = <&gpio1 2 GPIO_ACTIVE_LOW>;
			label = "RGB Red Led";
		};
	};

	buttons {
		compatible = "gpio-keys";

		user_btn: button_0 {
			label = "User Button";
			gpios = <&gpio0 4 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_KEY_0>;
		};
	};
};

&syscon {
	status = "okay";
};

&iocon {
	status = "okay";
};

&uart0 {
	status = "okay";
	clock-source = "frg0";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&swm {
	status = "okay";

	uart0_default: uart0_default {
		group0 {
			pinmux = <LPC84X_PINMUX_M(LPC84X_SWM_USART0_TXD, P0_25)>,
				 <LPC84X_PINMUX_M(LPC84X_SWM_USART0_RXD, P0_24)>;
		};
	};
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&i2c0 {
	status = "okay";
	clock-source = "fro";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";
};

&i2c1 {
	status = "okay";
	clock-source = "fro";
	pinctrl-0 = <&i2c1_default>;
	pinctrl-names = "default";
};

&i2c2 {
	status = "okay";
	clock-source = "fro";
	pinctrl-0 = <&i2c2_default>;
	pinctrl-names = "default";
};

&i2c3 {
	status = "okay";
	clock-source = "fro";
	pinctrl-0 = <&i2c3_default>;
	pinctrl-names = "default";
};

&swm {
	i2c0_default: i2c0_default {
		group0 {
			pinmux = <LPC84X_PINMUX_F(LPC84X_SWM_I2C0_SCL, P0_10)>,
				 <LPC84X_PINMUX_F(LPC84X_SWM_I2C0_SDA, P0_11)>;
			drive-open-drain;
		};
	};

	i2c1_default: i2c1_default {
		group0 {
			pinmux = <LPC84X_PINMUX_M(LPC84X_SWM_I2C1_SCL, P0_28)>,
				 <LPC84X_PINMUX_M(LPC84X_SWM_I2C1_SDA, P0_27)>;
			bias-pull-up;
			drive-open-drain;
		};
	};

	i2c2_default: i2c2_default {
		group0 {
			pinmux = <LPC84X_PINMUX_M(LPC84X_SWM_I2C2_SCL, P0_8)>,
				 <LPC84X_PINMUX_M(LPC84X_SWM_I2C2_SDA, P0_9)>;
			bias-pull-up;
			drive-open-drain;
		};
	};

	i2c3_default: i2c3_default {
		group0 {
			pinmux = <LPC84X_PINMUX_M(LPC84X_SWM_I2C3_SCL, P0_0)>,
				 <LPC84X_PINMUX_M(LPC84X_SWM_I2C3_SDA, P0_1)>;
			bias-pull-up;
			drive-open-drain;
		};
	};
};

&pint {
	status = "okay";
};
