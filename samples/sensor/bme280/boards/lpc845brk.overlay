#include <zephyr/dt-bindings/gpio/gpio.h>

&spi0 {
	status = "okay";
	pinctrl-0 = <&spi0_default>;
	pinctrl-names = "default";
	clock-source = "fro";
	cs-gpios = <&gpio0 28 GPIO_ACTIVE_LOW>;

	bme280@0 {
		compatible = "bosch,bme280";
		reg = <0>;
		spi-max-frequency = <1000000>;
	};
};
